# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# --- AI ---
# Pick one provider, or leave both blank for deterministic fallback narration.
#
# (a) Local / self-hosted Ollama  →  set AI_PROVIDER=ollama
# AI_PROVIDER="ollama"
# OLLAMA_HOST="http://127.0.0.1:11434"
# OLLAMA_MODEL="qwen2.5:7b-instruct"   # recommended default
#
# (b) Anthropic Claude API  →  set AI_PROVIDER=anthropic (or leave unset)
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-5"  # optional override
ANTHROPIC_API_KEY=""

# --- Strava OAuth ---
# Create your app at https://www.strava.com/settings/api
# Authorization Callback Domain must be: localhost   (or the bare host you serve from)
AUTH_STRAVA_ID=""
AUTH_STRAVA_SECRET=""
